# --- API ---
PORT=4000
DATABASE_URL=postgresql://syncroute:syncroute@localhost:5433/syncroute
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# --- Routing ---
# Public OSRM (default). Flip to http://localhost:5000 after ./scripts/osrm-prepare.sh
OSRM_URL=https://routing.openstreetmap.de/routed-car
PHOTON_URL=https://photon.komoot.io

# --- Matching tunables ---
CORRIDOR_RADIUS_M=1500
MAX_DETOUR_MIN=10
DEVIATION_THRESHOLD_M=500
DEVIATION_STRIKES=3

# --- Payments (Razorpay TEST mode only) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Admin web (apps/admin/.env) ---
VITE_API_URL=http://localhost:4000
